                  "  const b = pm.response.json();",
                  "  pm.test('idToken present',      () => pm.expect(b.idToken).to.be.a('string').and.not.empty);",
                  "  pm.test('isNewUser is boolean', () => pm.expect(b.isNewUser).to.be.a('boolean'));",
                  "  console.log('isNewUser:', b.isNewUser);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
