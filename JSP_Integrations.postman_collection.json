            "url": { "raw": "{{base_url}}/v1/games/active", "host": ["{{base_url}}"], "path": ["v1", "games", "active"] }
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }]
        },
        {
          "name": "Search Games",
          "request": {
            "method": "GET",
